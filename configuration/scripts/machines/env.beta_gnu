#!/bin/csh -f

setenv ICE_MACHINE_ENVNAME beta
setenv ICE_MACHINE_COMPILER gnu
setenv ICE_MACHINE_MAKE gmake
setenv ICE_MACHINE_WKDIR ~/Documents/CICE_RUNS
setenv ICE_MACHINE_INPUTDATA ~/Documents/CICE
setenv ICE_MACHINE_BASELINE ~/Documents/CICE_BASELINE
setenv ICE_MACHINE_SUBMIT "qsub"
setenv ICE_MACHINE_TPNODE 1
setenv ICE_MACHINE_QUEUE "default"
setenv ICE_MACHINE_ACCT P0000000
setenv ICE_MACHINE_BLDTHRDS 1
#setenv ICE_MACHINE_QSTAT "qstat "
